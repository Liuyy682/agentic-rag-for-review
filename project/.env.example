# Required for the RAG app
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000

# Hugging Face models (optional)
# Use this mirror when direct Hugging Face access is unstable.
# HF_ENDPOINT=https://hf-mirror.com
HF_HUB_OFFLINE=1
DENSE_LOCAL_FILES_ONLY=false
RERANKER_LOCAL_FILES_ONLY=false

# Multimodal PDF ingestion (optional)
# PDF_EXTRACT_IMAGES=true stores PDF picture regions under document_images/<pdf-name>/.
PDF_EXTRACT_IMAGES=true
PDF_IMAGE_DPI=150
PDF_IMAGE_FORMAT=png

# --- Image Analysis Engine ---
# Choose how to analyze images embedded in documents.
# Options:
#   paddleocr - Fast, local OCR via PaddleOCR (best Chinese accuracy, ~500MB models)
#   vlm       - Vision Language Model via OpenAI-compatible API (slower, semantic understanding)
#   none      - Skip image analysis entirely (default)
IMAGE_ANALYSIS_ENGINE=none

# PaddleOCR settings (when IMAGE_ANALYSIS_ENGINE=paddleocr)
# Language: ch (Chinese), en (English), ch_en (Chinese + English)
PADDLEOCR_LANG=ch
PADDLEOCR_USE_GPU=false

# Common OCR thresholds (applies to paddleocr engine)
OCR_IMAGE_MIN_WIDTH=80
OCR_IMAGE_MIN_HEIGHT=40
OCR_IMAGE_MAX_PER_DOC=80
OCR_IMAGE_ANALYSIS_WORKERS=2

# VLM settings (when IMAGE_ANALYSIS_ENGINE=vlm)
# Enable this after starting a local OpenAI-compatible VLM server.
# Examples: vLLM at http://localhost:8000/v1, Ollama OpenAI-compatible API at http://localhost:11434/v1.
VLM_IMAGE_CAPTION_ENABLED=false
LOCAL_VLM_BASE_URL=http://localhost:8000/v1
LOCAL_VLM_API_KEY=EMPTY
LOCAL_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VLM_TIMEOUT_SECONDS=120
LOCAL_VLM_MAX_TOKENS=800
VLM_IMAGE_MIN_WIDTH=80
VLM_IMAGE_MIN_HEIGHT=40
VLM_IMAGE_CONTEXT_CHARS=1200
VLM_IMAGE_MAX_PER_DOC=80
VLM_IMAGE_ANALYSIS_WORKERS=1
